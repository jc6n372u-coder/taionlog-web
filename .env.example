# =============================================================
# 環境変数テンプレート
# =============================================================
#
# このファイルは Git 管理に含まれます (テンプレート)。
# 実際の値は .env (Git 管理外) に書くか、
# 本番デプロイ時は Cloudflare Pages の「変数とシークレット」に設定してください。
#
# === セキュリティ重要事項 ===
# VITE_ プレフィックス付き変数はビルド時にバンドル JS に静的に
# 埋め込まれます。そのためブラウザ側で値を見ることが可能です。
# 本物のシークレットを VITE_ で配信しないでください。
# 現状の VITE_API_SECRET は「軽い保護のための共有秘密キー」です。
# =============================================================

# GAS Web App の URL
# https://script.google.com/macros/s/{DEPLOY_ID}/exec
VITE_GAS_BASE_URL=https://script.google.com/macros/s/__YOUR_DEPLOY_ID__/exec

# GAS スクリプトプロパティ API_SECRET と同じ値を入れる
# (32 文字以上のランダム文字列を推奨)
VITE_API_SECRET=__YOUR_API_SECRET__
